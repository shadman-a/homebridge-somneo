  "item": [
    {
      "name": "Wake And Alarm",
      "description": "Native wake-alarm endpoints discovered from the Philips app and verified live on the Somneo.",
      "item": [
        {
          "name": "GET Wake Alarm Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm",
            "description": "Root wake-alarm summary. Live response fields included snztm, aenvs, alctr, aalms, prfnr, and prfwu."
          },
          "response": []
        },
        {
          "name": "GET Wake Alarm Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/prfwu",
            "description": "Current wake profile. Live response fields included prfnr, prfen, prfvs, almhr, almmn, curve, durat, ctype, snddv, sndch, sndlv, sndss, pwrsz, pszhr, and pszmn."
          },
          "response": []
        },
        {
          "name": "PUT Arm Wake Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prfnr\": {{profileNumber}},\n  \"prfen\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/prfwu",
            "description": "Minimal live-tested arm request."
          },
          "response": []
        },
        {
          "name": "PUT Disarm Wake Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prfnr\": {{profileNumber}},\n  \"prfen\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/prfwu",
            "description": "Minimal live-tested disarm request."
          },
          "response": []
        },
        {
          "name": "PUT Set Wake Time And Arm",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prfnr\": {{profileNumber}},\n  \"prfen\": true,\n  \"prfvs\": true,\n  \"pname\": \"\",\n  \"ayear\": 0,\n  \"amnth\": 0,\n  \"alday\": 0,\n  \"daynm\": 0,\n  \"almhr\": {{wakeHour}},\n  \"almmn\": {{wakeMinute}},\n  \"curve\": {{curve}},\n  \"durat\": {{duration}},\n  \"ctype\": {{ctype}},\n  \"snddv\": \"{{soundDevice}}\",\n  \"sndch\": \"{{soundChannel}}\",\n  \"sndlv\": {{soundLevel}},\n  \"sndss\": {{soundSession}},\n  \"pwrsz\": {{powerWakeEnabled}},\n  \"pszhr\": {{powerWakeHour}},\n  \"pszmn\": {{powerWakeMinute}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/prfwu",
            "description": "Full wake-profile template based on the live profile shape returned by the device. Safer workflow: GET /wualm/prfwu, copy the body, change only the fields you want, then PUT it back."
          },
          "response": []
        },
        {
          "name": "GET Wake Alarm Schedule Arrays",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/aalms",
            "description": "Bulk alarm schedule arrays. Live response included ayear, amnth, alday, daynm, almhr, and almmn. Do not blindly PUT this endpoint."
          },
          "response": []
        },
        {
          "name": "GET Wake Alarm Enabled States",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/aenvs",
            "description": "Bulk alarm enabled and visible states. Live response included prfen, prfvs, pwrsv, and utcof. Do not blindly PUT this endpoint."
          },
          "response": []
        },
        {
          "name": "GET Wake Alarm Controls",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/alctr",
            "description": "Alarm action/control state. Live response included tapsz and disms."
          },
          "response": []
        },
        {
          "name": "PUT Set Snooze Duration",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"snztm\": {{snoozeMinutes}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm",
            "description": "Live-tested snooze duration write."
          },
          "response": []
        }
      ]
    },
