{
  "info": {
    "_postman_id": "8a928c8a-6484-4d5d-b7ea-5b6bc9f68910",
    "name": "Philips Somneo LAN API",
    "description": "Reverse-engineered Philips Somneo LAN API collection for the live unit at 192.168.12.219.\n\nImportant:\n- The Somneo uses a self-signed TLS certificate. In Postman, disable SSL certificate verification before using this collection.\n- The safest write flow for wake alarms is GET /wualm/prfwu, modify only the fields you need, then PUT the full profile back.\n- GET endpoints in this collection are confirmed live on the device.\n- PUT /wualm/prfwu, PUT /wualm/alctr, and PUT /wualm with snztm were also live-tested.\n- Be careful with /wualm/aalms and /wualm/aenvs writes. Those endpoints appear writable, but they behaved unexpectedly on live round-trips and are not included as write requests here.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "protocol",
      "value": "https"
    },
    {
      "key": "host",
      "value": "192.168.12.219"
    },
    {
      "key": "profileNumber",
      "value": "5"
    },
    {
      "key": "wakeHour",
      "value": "7"
    },
    {
      "key": "wakeMinute",
      "value": "0"
    },
    {
      "key": "curve",
      "value": "20"
    },
    {
      "key": "duration",
      "value": "30"
    },
    {
      "key": "ctype",
      "value": "0"
    },
    {
      "key": "soundDevice",
      "value": "wus"
    },
    {
      "key": "soundChannel",
      "value": "1"
    },
    {
      "key": "soundLevel",
      "value": "12"
    },
    {
      "key": "soundSession",
      "value": "30000"
    },
    {
      "key": "powerWakeEnabled",
      "value": "0"
    },
    {
      "key": "powerWakeHour",
      "value": "8"
    },
    {
      "key": "powerWakeMinute",
      "value": "17"
    },
    {
      "key": "snoozeMinutes",
      "value": "9"
    },
    {
      "key": "lightLevel",
      "value": "12"
    },
    {
      "key": "audioVolume",
