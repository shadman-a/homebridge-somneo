              "raw": "{\n  \"tapsz\": false,\n  \"disms\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wualm/alctr",
            "description": "Clears the active alarm control flags after testing."
          },
          "response": []
        },
        {
          "name": "GET Device Wake Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{protocol}}://{{host}}/di/v1/products/1/wusts",
            "description": "Device status endpoint. Live response fields included wusts, rpair, pwrsz, snztm, brght, dspon, wutim, dutim, and sntim."
          },
          "response": []
        }
      ]
    },
